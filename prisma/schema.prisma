// Prisma schema for Luie
// Database: SQLite
// ORM: Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// Durable models (master data)
// 프로젝트 - 최상위 단위
model Project {
  id          String   @id @default(uuid())
  title       String
  description String?
  projectPath String? // 레거시 로컬 attachment 경로 (canonical 아님)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  attachment      ProjectAttachment?
  localState      ProjectLocalState?
  chapters        Chapter[]
  characters      Character[]
  terms           Term[]
  events          Event[]
  factions        Faction[]
  snapshots       Snapshot[]
  settings        ProjectSettings?
  worldEntities   WorldEntity[]
  entityRelations EntityRelation[]
  worldDocuments  WorldDocument[]
  scrapMemos      ScrapMemo[]
}

// 앱 로컬 attachment metadata.
// canonical project content가 아니라 현재 기기에서 어떤 .luie에 연결됐는지 표현한다.
model ProjectAttachment {
  projectId   String   @id
  projectPath String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// 앱 로컬 프로젝트 상태.
// 최근 프로젝트 정렬과 마지막 열기 시각처럼 기기 의존 메타데이터만 저장한다.
model ProjectLocalState {
  projectId     String    @id
  lastOpenedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// 프로젝트별 로컬 런타임 정책.
// 현재 필드는 portable canonical content가 아니라 replica/app-local 성격이다.
model ProjectSettings {
  id               String  @id @default(uuid())
  projectId        String  @unique
  autoSave         Boolean @default(true)
  autoSaveInterval Int     @default(30) // seconds

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// 챕터/회차 - 집필 단위
model Chapter {
  id        String    @id @default(uuid())
  projectId String
  title     String
  content   String    @default("")
  synopsis  String?
  order     Int
  wordCount Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  snapshots Snapshot[]

  @@index([projectId, order])
}

// 캐릭터 관리
model Character {
  id              String   @id @default(uuid())
  projectId       String
  name            String
  description     String?
  firstAppearance String? // User-visible metadata with optional auto-fill; not rebuildable cache
  attributes      String? // JSON field for flexible attributes
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, name])
}

// 사건 관리
model Event {
  id              String   @id @default(uuid())
  projectId       String
  name            String
  description     String?
  firstAppearance String? // User-visible metadata with optional auto-fill; not rebuildable cache
  attributes      String? // JSON field for flexible attributes
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, name])
}

// 세력 관리
model Faction {
  id              String   @id @default(uuid())
  projectId       String
  name            String
  description     String?
  firstAppearance String? // User-visible metadata with optional auto-fill; not rebuildable cache
  attributes      String? // JSON field for flexible attributes
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, name])
}

// Detached/synced 프로젝트가 .luie attachment 없이도 편집될 수 있도록
// world 문서를 로컬 replica DB에 보관한다.
model WorldDocument {
  id        String   @id @default(uuid())
  projectId String
  docType   String
  payload   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, docType])
  @@index([projectId, updatedAt])
}

// Scrap memo는 sync/materialize를 위해 개별 row도 유지한다.
// `.luie` payload와 replica row는 함께 갱신된다.
model ScrapMemo {
  id        String   @id
  projectId String
  title     String
  content   String
  tags      String   @default("[]") // JSON array
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
  @@index([projectId, updatedAt])
}

// 고유명사 사전
model Term {
  id              String   @id @default(uuid())
  projectId       String
  term            String
  definition      String?
  category        String? // e.g., "location", "item", "concept"
  order           Int      @default(0)
  firstAppearance String? // User-visible metadata with optional auto-fill; not rebuildable cache
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, term])
}

// 스냅샷 (버전 관리, canonical user data)
// 캐시가 아니며 복구/히스토리 의미를 보존해야 한다.
enum SnapshotType {
  AUTO
  MANUAL
}

model Snapshot {
  id            String       @id @default(uuid())
  projectId     String
  chapterId     String?
  content       String
  contentLength Int          @default(0)
  type          SnapshotType @default(AUTO)
  description   String?
  createdAt     DateTime     @default(now())

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter Chapter? @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([projectId, chapterId, createdAt])
  @@index([projectId, type, createdAt])
}

// ─── World Building ─────────────────────────────────────────────────────────

// 범용 세계관 엔티티: Place / Concept / Rule / Item
model WorldEntity {
  id              String   @id @default(uuid())
  projectId       String
  type            String
  name            String
  description     String?
  firstAppearance String? // User-visible metadata with optional auto-fill; not rebuildable cache
  attributes      String?
  positionX       Float    @default(0)
  positionY       Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project           Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  relationsAsSource EntityRelation[] @relation("RelationSource")
  relationsAsTarget EntityRelation[] @relation("RelationTarget")

  @@index([projectId, type])
  @@index([projectId, name])
}

// 6종 관계: belongs_to / enemy_of / causes / controls / located_in / violates
model EntityRelation {
  id                  String   @id @default(uuid())
  projectId           String
  sourceId            String
  sourceType          String
  targetId            String
  targetType          String
  relation            String
  attributes          String?
  sourceWorldEntityId String?
  targetWorldEntityId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceEntity WorldEntity? @relation("RelationSource", fields: [sourceWorldEntityId], references: [id], onDelete: Cascade)
  targetEntity WorldEntity? @relation("RelationTarget", fields: [targetWorldEntityId], references: [id], onDelete: Cascade)

  @@index([projectId, sourceId])
  @@index([projectId, targetId])
  @@index([projectId, relation])
}
