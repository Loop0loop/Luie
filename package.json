{
  "name": "luie",
  "version": "0.1.33",
  "description": "흐름을 방해하지 않는 집필 도구",
  "main": "out/main/index.js",
  "type": "module",
  "author": "Luie Team",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "predev": "pnpm rebuild:electron",
    "dev": "electron-vite",
    "build": "electron-vite build",
    "build:debug-profile": "LUIE_DEBUG_PROFILE=1 electron-vite build",
    "graph:profile": "node scripts/graph-perf-session.mjs",
    "prepreview": "pnpm rebuild:electron",
    "preview": "electron-vite preview",
    "preview:prod": "pnpm run build && NODE_ENV=production electron .",
    "build:mac": "pnpm build:mac:arm64 && pnpm build:mac:universal && node scripts/release-mac.mjs",
    "build:mac:package": "pnpm build:mac:arm64",
    "build:mac:arm64": "pnpm generate && pnpm run stage:embedding-model && pnpm run build && DEBUG=electron-builder,electron-notarize ELECTRON_BUILDER_CACHE=.cache/electron-builder pnpm exec electron-builder --mac --arm64 --config electron-builder.json --publish never",
    "build:mac:universal": "pnpm generate && pnpm run stage:embedding-model && pnpm run build && DEBUG=electron-builder,electron-notarize ELECTRON_BUILDER_CACHE=.cache/electron-builder pnpm exec electron-builder --mac --universal --config electron-builder.json --publish never",
    "build:win": "pnpm build:win:x64",
    "build:win:x64": "pnpm generate && pnpm run stage:embedding-model && pnpm run build && pnpm exec electron-builder --win --x64 --config electron-builder.json --publish never",
    "build:win:arm64": "pnpm generate && pnpm run stage:embedding-model && pnpm run build && pnpm exec electron-builder --win --arm64 --config electron-builder.json --publish never",
    "build:win:all": "pnpm build:win:x64 && pnpm build:win:arm64",
    "build:linux": "pnpm generate && pnpm run stage:embedding-model && pnpm run build && pnpm exec electron-builder --linux --config electron-builder.json",
    "stage:embedding-model": "node scripts/stage-embedding-model.mjs",
    "postinstall": "npx electron --version && pnpm run rebuild:electron",
    "rebuild:electron": "cross-env CXXFLAGS=\"-std=c++20 -DV8_ENABLE_SANDBOX=1 -DV8_31BIT_SMIS_ON_64BIT_ARCH=1\" electron-rebuild --force -w better-sqlite3 --build-from-source",
    "generate": "pnpm generate:icons",
    "generate:drizzle": "pnpm generate:drizzle:main && pnpm generate:drizzle:cache",
    "generate:drizzle:main": "drizzle-kit generate --config=drizzle.main.config.ts",
    "generate:drizzle:cache": "drizzle-kit generate --config=drizzle.cache.config.ts",
    "check:drizzle": "pnpm check:drizzle:main && pnpm check:drizzle:cache",
    "check:drizzle:main": "drizzle-kit check --config=drizzle.main.config.ts",
    "check:drizzle:cache": "drizzle-kit check --config=drizzle.cache.config.ts",
    "generate:icons": "node scripts/generate-app-icons.mjs",
    "supabase:openai:link": "node scripts/supabase-openai.mjs link",
    "supabase:openai:set-secret": "node scripts/supabase-openai.mjs set-secret",
    "supabase:openai:deploy": "node scripts/supabase-openai.mjs deploy",
    "supabase:openai:serve": "node scripts/supabase-openai.mjs serve",
    "supabase:llm:link": "node scripts/supabase-openai.mjs link",
    "supabase:llm:set-secret": "node scripts/supabase-openai.mjs set-secret",
    "supabase:llm:deploy": "node scripts/supabase-openai.mjs deploy",
    "typecheck": "tsc --noEmit",
    "check:deps": "node scripts/check-deps.mjs",
    "check:no-native-dialogs": "node scripts/check-no-native-dialogs.mjs",
    "check:i18n-parity": "node scripts/check-i18n-parity.mjs",
    "check:no-escape-hatches": "node scripts/check-no-escape-hatches.mjs",
    "check:version-pins": "node scripts/check-version-pins.mjs",
    "check:build-warning-regression": "node scripts/check-build-warning-regression.mjs",
    "check:ipc-contract-map": "node scripts/check-ipc-contract-map.mjs",
    "check:ipc-handler-schemas": "node scripts/check-ipc-handler-schemas.mjs",
    "check:security-profile": "node scripts/check-security-profile.mjs",
    "check:utility-process-boundary": "node scripts/check-utility-process-boundary.mjs",
    "check:renderer-store-usage": "node scripts/check-renderer-store-usage.mjs",
    "check:persist-contracts": "node scripts/check-persist-contracts.mjs",
    "check:target-file-drift": "node scripts/check-target-file-drift.mjs",
    "check:preload-contract-regression": "node scripts/check-preload-contract-regression.mjs",
    "check:core-complexity": "node scripts/check-core-complexity.mjs",
    "check:source-loc": "node scripts/check-source-loc.mjs",
    "verify:packaged-drizzle": "node scripts/verify-packaged-drizzle.mjs",
    "bench:derived-db": "node scripts/benchmark-derived-db.mjs",
    "bench:writing-loop:profiles": "node scripts/run-writing-loop-profiles.mjs",
    "bench:writing-loop:profiles:all": "node scripts/run-writing-loop-profiles.mjs --include-500",
    "bench:writing-loop:repeat": "node scripts/run-writing-loop-repeat.mjs",
    "bench:writing-loop:fullprod": "pnpm exec playwright test --project=stress tests/e2e/writingLoop.fullprod.spec.ts",
    "bench:writing-loop:fullprod:repeat": "node scripts/run-writing-loop-fullprod-repeat.mjs",
    "resilience:luie:report": "node scripts/luie-resilience-report.mjs",
    "resilience:luie": "node scripts/luie-resilience-report.mjs --run-all",
    "check:writing-loop-regression": "node scripts/check-writing-loop-regression.mjs",
    "check:writing-loop-profiles-regression": "node scripts/check-writing-loop-profiles-regression.mjs",
    "check:derived-db-bench": "node scripts/benchmark-derived-db.mjs --assert --json-out tests/.tmp/derived-db-bench.json",
    "memory:calibrate": "tsx scripts/run-memory-production-calibration.ts",
    "memory:rebuild-chunks": "tsx scripts/rebuild-memory-chunks.ts",
    "memory:process-entities": "tsx scripts/process-memory-entities.ts",
    "memory:process-episodes": "tsx scripts/process-memory-episode-jobs.ts",
    "memory:process-temporal-facts": "tsx scripts/process-memory-temporal-facts.ts",
    "memory:repair-evidence-links": "tsx scripts/repair-memory-evidence-links.ts",
    "memory:process-narrative-summaries": "tsx scripts/process-memory-narrative-summaries.ts",
    "memory:audit-canonical-export": "tsx scripts/audit-memory-canonical-export.ts",
    "memory:export-canonical-package": "tsx scripts/export-memory-canonical-package.ts",
    "memory:verify-canonical-package-sync": "tsx scripts/verify-memory-canonical-package-sync.ts",
    "memory:review-backlog": "tsx scripts/memory-review-backlog.ts",
    "memory:review-template": "tsx scripts/generate-memory-review-template.ts",
    "memory:apply-review-decisions": "tsx scripts/apply-memory-review-decisions.ts",
    "memory:materialize-eval-cases": "tsx scripts/materialize-memory-eval-cases.ts",
    "memory:phase-status": "tsx scripts/memory-phase-status.ts",
    "lint-all": "pnpm run check:deps && pnpm run check:no-native-dialogs && pnpm run check:i18n-parity && pnpm run check:no-escape-hatches && pnpm run check:version-pins && pnpm run check:ipc-contract-map && pnpm run check:ipc-handler-schemas && pnpm run check:security-profile && pnpm run check:utility-process-boundary && pnpm run check:renderer-store-usage && pnpm run check:persist-contracts && pnpm run check:preload-contract-regression && pnpm run check:source-loc && eslint src --ext .ts,.tsx",
    "lint": "eslint src --ext .ts,.tsx",
    "qa:core": "pnpm run typecheck && pnpm run lint && pnpm run check:utility-process-boundary && pnpm run check:renderer-store-usage && pnpm run check:ipc-handler-schemas && pnpm run check:persist-contracts && pnpm run check:core-complexity && pnpm run check:source-loc && pnpm run check:target-file-drift && pnpm run check:build-warning-regression && pnpm run check:derived-db-bench && SKIP_DB_TEST_SETUP=1 pnpm vitest tests/main/lifecycle/deepLink.test.ts tests/main/handler/ipcWindowHandlers.test.ts tests/main/handler/ipcInputValidation.test.ts tests/main/services/syncAuthService.test.ts tests/main/services/syncService.test.ts tests/main/services/syncMapper.test.ts tests/main/services/syncRepository.test.ts tests/main/services/exportService.test.ts tests/renderer/hooks/useTermDragDrop.test.ts tests/renderer/services/exportEntryService.test.ts tests/renderer/services/worldPackageStorage.test.ts tests/renderer/stores/projectLayoutStore.test.ts tests/renderer/stores/projectLayoutStore.persist.test.ts tests/renderer/stores/uiStore.persist.test.ts tests/renderer/stores/memoStore.test.ts tests/renderer/utils/sanitizeHtml.test.ts tests/shared/utils/exportContentNormalization.test.ts tests/dom/focusHoverSidebar.test.tsx tests/dom/rendererRerenderRegression.test.tsx tests/dom/appOperationalScenarios.test.tsx tests/dom/projectInitOperationalScenarios.test.tsx tests/scripts/buildWarningNormalization.test.ts tests/scripts/preloadContractRegression.test.ts tests/scripts/rendererCspPolicy.test.ts tests/scripts/ipcContractMap.test.ts tests/scripts/ipcHandlerSchemas.test.ts tests/scripts/dependencyIntegrity.test.ts tests/scripts/securityProfile.test.ts tests/scripts/rendererStoreUsage.test.ts tests/scripts/persistContracts.test.ts tests/scripts/utilityProcessBoundary.test.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "test": "pnpm rebuild better-sqlite3 && vitest",
    "test:ui-mode-integrity": "SKIP_DB_TEST_SETUP=1 vitest tests/renderer/services/uiModeIntegrity.test.ts tests/renderer/services/layoutModeActions.integrity.test.ts tests/renderer/stores/editorStore.uiModeIntegrity.test.ts",
    "test:prepare": "electron-rebuild --force --version $(node -p \"require('electron/package.json').version\")",
    "test:e2e": "pnpm test:prepare && pnpm build && playwright test --project=e2e",
    "test:stress": "pnpm test:prepare && pnpm build && playwright test --project=stress",
    "test:vr": "pnpm build && playwright test --project=visual",
    "test:smoke": "pnpm test:prepare && pnpm build && playwright test --project=smoke"
  },
  "dependencies": {
    "@google/genai": "2.7.0",
    "better-sqlite3": "12.10.0",
    "docx": "9.7.1",
    "drizzle-orm": "0.45.2",
    "electron-store": "11.0.2",
    "electron-window-state": "5.0.3",
    "jszip": "3.10.1",
    "sanitize-filename": "1.6.4",
    "sqlite-vec": "0.1.9",
    "yauzl": "3.3.2",
    "yazl": "3.3.1",
    "zod": "4.4.3"
  },
