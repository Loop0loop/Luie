    "@types/yauzl": "2.10.3",
    "@types/yazl": "3.3.1",
    "@typescript-eslint/eslint-plugin": "8.60.0",
    "@typescript-eslint/parser": "8.60.0",
    "@vitejs/plugin-react": "6.0.2",
    "autoprefixer": "10.5.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "cross-env": "10.1.0",
    "dagre": "0.8.5",
    "diff": "9.0.0",
    "dompurify": "3.4.7",
    "dotenv": "17.4.2",
    "dotenv-cli": "11.0.0",
    "drizzle-kit": "0.31.10",
    "electron": "42.3.0",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "eslint": "10.4.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "i18next": "26.3.0",
    "i18next-browser-languagedetector": "8.2.1",
    "jsdom": "29.1.1",
    "lucide-react": "1.17.0",
    "postcss": "8.5.15",
    "prettier": "3.8.3",
    "prosemirror-model": "1.25.7",
    "prosemirror-state": "1.4.4",
    "prosemirror-view": "1.41.8",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-i18next": "17.0.8",
    "react-resizable-panels": "4.11.2",
    "react-virtuoso": "4.18.7",
    "reactflow": "11.11.4",
    "supabase": "2.102.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vite": "8.0.14",
    "vitest": "4.1.7",
    "zustand": "5.0.14"
  },
  "overrides": {
